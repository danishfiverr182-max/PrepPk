# ── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────
# Your MongoDB Atlas (or local) connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex
# How long admin session tokens last (e.g. 7d, 30d)
JWT_EXPIRES_IN=7d

# ── Admin Secret Path ─────────────────────────────────────────
# The URL prefix where the admin auth API is mounted.
# Use a hard-to-guess path to obscure the admin panel from scanners.
# Example: /admin-x9k2  or  /mgmt-a7z3
# Must start with a forward slash. Must match the Vite proxy target.
ADMIN_SECRET_PATH=/admin-x9k2

# ── Session / Cookie ─────────────────────────────────────────
# How many days the admin "remember me" cookie lasts
SESSION_DAYS=7

# ── Email (SMTP) ──────────────────────────────────────────────
# Used to send 6-digit verification codes on registration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
# Use a Gmail App Password (not your account password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ── CORS / Frontend ───────────────────────────────────────────
# Also used by /sitemap.xml and /robots.txt to build absolute URLs.
# In production set this to your real public domain: https://www.prepkp.com
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ── Google OAuth (optional used in later prompts) ───────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_secret
# Public base URL of THIS server (used to build the Google callback URL).
# In production this must be your real domain, e.g. https://api.yoursite.com
SERVER_URL=http://localhost:5000
# Override only if you need a fully custom callback URL instead of
# SERVER_URL + ADMIN_SECRET_PATH + /auth/google/callback
# GOOGLE_CALLBACK_URL=http://localhost:5000/admin-x9k2/auth/google/callback

# ── Session secret (Passport OAuth handshake only) ────────────
SESSION_SECRET=7e4a8c1f9d2b6e5a3c8f0d1b4e7a9c2f5d8b1e4a7c0f3d6e9b2a5c8f1d4e7a0

# ── Cloudinary (Non-Verbal image uploads) ────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── AI Chatbot — "PrepPk AI Study Assistant" ──────────────────
# Provider API keys (Groq, Gemini, OpenAI, Anthropic, OpenRouter) are NOT
# configured via .env. They are added and rotated at runtime through the
# admin panel's "API Key Pool" page, encrypted at rest in MongoDB using
# ENCRYPTION_KEY below. The server boots fine with zero keys configured —
# the chatbot will just return "temporarily unavailable" until an admin
# adds at least one key after deployment.

# ── Multi-provider API Key Vault (Part 12) ────────────────────
# 32-byte (64 hex character) key used to encrypt/decrypt provider API
# keys stored in MongoDB (server/models/ApiKey.js), via AES-256-GCM.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER reuse JWT_SECRET or SESSION_SECRET for this — generate a
# dedicated key, and never commit the real value to version control.
# Rotating this key will make all previously-encrypted keys undecryptable,
# so back up existing ApiKey documents (or re-enter the raw keys) if you
# ever need to change it.
ENCRYPTION_KEY=your_64_char_hex_encryption_key
